# === BOT ===
BOT_TOKEN="123456:ABC-DEF"
BOT_USERNAME="quototbot"

# === DATABASE ===
# docker-compose builds the app's DB_URL from these (no secrets live in compose).
POSTGRES_USER="quoto"
POSTGRES_PASSWORD="change-me-to-a-strong-password"
POSTGRES_DB="quoto"
# Only needed when running the bot OUTSIDE docker (compose overrides this):
DB_URL="postgresql+asyncpg://quoto:change-me-to-a-strong-password@localhost:5432/quoto"

# === AI (OpenRouter) ===
OPENROUTER_API_KEY="sk-or-v1-your-key-here"
OPENROUTER_EVAL_MODEL="google/gemini-3.5-flash"
OPENROUTER_EVAL_REASONING_EFFORT="medium"
OPENROUTER_EVAL_MAX_TOKENS=32000
OPENROUTER_MEDIA_MODEL="nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free"
# Used only if the primary media model errors out after retries.
OPENROUTER_MEDIA_FALLBACK_MODEL="google/gemini-2.5-flash-lite"
OPENROUTER_MEDIA_REASONING_EFFORT="medium"
OPENROUTER_HTTP_REFERER="https://t.me/quototbot"
OPENROUTER_APP_TITLE="Quoto"

# === MEDIA ===
MEDIA_ANALYSIS_ENABLED=True
MEDIA_PHASH_DISTANCE=5
MEDIA_CACHE_PROMPT_VERSION="v2"
MEDIA_IMAGE_MAX_SIDE=1280
MEDIA_IMAGE_QUALITY=82
MEDIA_VIDEO_MAX_SECONDS=3600
MEDIA_VIDEO_LOW_RES_MAX_SECONDS=10800
MEDIA_VIDEO_MAX_HEIGHT=720
MEDIA_VIDEO_CRF=30
MEDIA_VIDEO_FPS=12
MEDIA_AUDIO_BITRATE="64k"
MEDIA_AUDIO_SAMPLE_RATE=24000
MEDIA_COMMAND_TIMEOUT_SECONDS=300
MEDIA_PENDING_RETRY_INTERVAL_SECONDS=300
MEDIA_PENDING_RETRY_BATCH_SIZE=10
MEDIA_PENDING_ITEM_TIMEOUT_SECONDS=600

# === DEVELOPERS ===
ENABLE_DEVELOPERS_NOTIFY=False
DEVELOPER_IDS=[123456789]

# === SCHEDULER ===
QUOTE_HOUR=21
QUOTE_MINUTE=0
TIMEZONE="Europe/Kyiv"
MIN_MESSAGES_FOR_AUTO_REVIEW=10

# === LIMITS ===
# Max messages fed to the AI per group per day (cost safety). Groups above this
# keep only the most recent N and get a "context trimmed" note on the quote.
MAX_MESSAGES_PER_DAILY_EVAL=1500
# Premium groups bypass the message cap entirely. JSON list of chat ids.
PREMIUM_CHAT_IDS=[]

# === SCORING ===
# Final score is AI-only; reactions and length are sent/stored as context.
WEIGHT_REACTIONS=0.0
WEIGHT_AI=1.0
WEIGHT_LENGTH=0.0
